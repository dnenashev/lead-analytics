# Lead Analytics Service

# API
API_KEY=change-me-to-something-secure
PORT=8000

# LLM Provider (gemini or deepseek)
LLM_PROVIDER=mock
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Bitrix24 CRM
BITRIX24_WEBHOOK_URL=

# AmoCRM
AMOCRM_TOKEN=

# Query both CRMs simultaneously (true) or just one (false)
USE_DUAL_CRM=true

USE_MOCKS=true

# Yandex Direct
YANDEX_DIRECT_TOKEN=
YANDEX_DIRECT_LOGIN=

# VK Ads (single account — fallback)
VK_ADS_TOKEN=
VK_ADS_ACCOUNT_ID=
# VK Ads (multiple accounts — JSON array)
# VK_ADS_ACCOUNTS=[{"account_id":"29762150","token":"..."},{"account_id":"29255064","token":"..."}]

# Paperclip Integration
PAPERCLIP_API_URL=https://paperclip-production-04e9.up.railway.app
PAPERCLIP_API_KEY=

# LangSmith Tracing (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=Cohort_Analyzer_Prod
LANGCHAIN_API_KEY=

# Analysis settings
MAX_RETRY_ATTEMPTS=3
DEFAULT_SAMPLE_SIZE=10
